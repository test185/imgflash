# =============================================================================
# ImgFlash v3 - Build Configuration
# =============================================================================
# Environment layering: build.env < environment variables
# =============================================================================

# Debian mirror for .deb downloads
DEBIAN_MIRROR="https://ftp.debian.org/debian"

# BusyBox static binary URL (x86_64, musl)
BUSYBOX_URL="https://busybox.net/downloads/binaries/1.36.1-x86_64-linux-musl/busybox"

# GNU coreutils version for static dd compilation
COREUTILS_VERSION="9.5"

# Squashfs compression algorithm (xz / gzip / zstd)
SQUASHFS_COMP="xz"

# Volume label for the ISO
VOLUME_LABEL="IMGFLASH"

# Required kernel modules (resolved with dependencies at build time)
REQUIRED_MODULES="squashfs isofs loop ahci nvme usb-storage sr_mod sd_mod cdrom virtio_blk virtio_pci"

# Network retry settings
RETRY_MAX=3
RETRY_DELAY=5

# Boot media scan timeout (seconds, used by /init at runtime)
SCAN_TIMEOUT=10
