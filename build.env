# ImgFlash 构建配置
# 修改此文件后重新构建即可生效

# --- 目标架构（amd64 / arm64） ---
ARCH=amd64

# --- Debian 仓库 ---
DEBIAN_MIRROR=https://ftp.debian.org/debian
DEBIAN_SUITE=trixie

# --- ISO 元数据 ---
VOLUME_LABEL=IMGFLASH

# --- 内核模块 ---
MOD_FILESYSTEM="squashfs isofs loop"
MOD_NLS="nls_cp437 nls_ascii nls_utf8"
MOD_ATA="ahci ata_piix ata_generic"
MOD_USB="xhci-hcd ehci-hcd usb-storage uas"
MOD_CDROM="sr_mod sd_mod cdrom"
MOD_INPUT="hid usbhid"
MOD_NVME="nvme"
MOD_VIRT="virtio virtio_blk virtio_pci virtio_scsi"

# --- 可选模块开关（设为 0 禁用，设为 1 启用） ---
INCLUDE_NVME=1
INCLUDE_VIRT=1

# --- 启动菜单超时（秒） ---
BOOT_TIMEOUT=3

# --- 内核启动参数 ---
KERNEL_PARAMS=quiet

# --- 启动扫描超时（秒） ---
SCAN_TIMEOUT=10

# --- 压缩级别 ---
ZSTD_LEVEL=19